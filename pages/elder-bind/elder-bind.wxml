<view class="page">
  <view class="hero-card">
    <text class="eyebrow">老人使用</text>
    <text class="hero-title">绑定家路通</text>
    <text class="hero-note">输入家人给的绑定码，绑定后就能看到路线。</text>
  </view>

  <view class="form-card">
    <text class="field-label">绑定码</text>
    <button class="scan-button" bindtap="scanBindCode">扫码绑定</button>
    <input
      class="field-input"
      value="{{bindCode}}"
      maxlength="12"
      confirm-type="done"
      placeholder="输入家人给的绑定码"
      bindinput="onInput"
    />
    <button class="primary-button" loading="{{submitting}}" bindtap="submit">微信绑定</button>
    <text class="safe-note">老人不用记账号密码，只需要使用微信确认一次。</text>
  </view>
</view>
