/* route-review 页面 - 路线审核详情 */
.family-page {
  min-height: 100vh;
  padding: var(--space-lg) var(--space-lg) 190rpx;
  background: var(--color-bg);
}

.loading-card,
.summary-card,
.route-tree-card,
.step-card {
  margin-bottom: var(--space-md);
  padding: var(--space-lg);
  border: 3rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
}

.route-tree-title {
  color: var(--color-text-primary);
  font-size: var(--font-lg);
  font-weight: var(--weight-heading);
}

.review-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
  padding: var(--space-xs);
  border: 3rpx solid var(--color-border);
  border-radius: 28rpx;
  background: var(--color-surface);
}

.review-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 86rpx;
  margin: 0;
  padding: 0;
  border-radius: var(--radius-md);
  background: var(--color-bg);
  color: #8d6a4f;
  font-size: var(--font-md);
  font-weight: var(--weight-body);
  line-height: 1.2;
}

.review-tab-active {
  background: var(--color-primary);
  color: var(--color-surface);
}

.compact-review-card {
  margin-bottom: var(--space-md);
  padding: var(--space-md);
  border: 3rpx solid var(--color-border);
  border-radius: 28rpx;
  background: var(--color-surface);
}

.compact-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.compact-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
}

.compact-title {
  color: var(--color-text-primary);
  font-size: var(--font-lg);
  font-weight: var(--weight-heading);
}

.compact-meta {
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-body);
}

.compact-status {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-pill);
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  font-size: var(--font-xs);
  font-weight: var(--weight-label);
}

.compact-hint {
  display: block;
  margin-top: var(--space-sm);
  padding: var(--space-sm);
  border-radius: 18rpx;
  background: var(--color-bg);
  color: var(--color-primary-dark);
  font-size: var(--font-sm);
  font-weight: var(--weight-body);
}

.review-pager {
  position: sticky;
  z-index: 10;
  top: 0;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
  padding: var(--space-sm);
  border: 3rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: rgba(255, 250, 245, 0.98);
}

.pager-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  margin: 0;
  padding: 0;
  border-radius: 18rpx;
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
  line-height: 1.2;
}

.pager-progress {
  color: var(--color-text-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-heading);
}

.pager-center {
  display: flex;
  min-width: 150rpx;
  flex-direction: column;
  align-items: center;
}

.pager-pending {
  margin-top: 4rpx;
  color: #8a6b54;
  font-size: var(--font-xs);
  font-weight: var(--weight-body);
}

.pending-jump-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  margin: 0 0 var(--space-md);
  padding: 0 var(--space-md);
  border: 2rpx dashed var(--color-primary);
  border-radius: var(--radius-md);
  background: var(--color-surface);
  color: var(--color-primary-dark);
  font-size: var(--font-base);
  font-weight: var(--weight-heading);
  line-height: 1.2;
}

.route-tree-item {
  display: flex;
  min-height: 92rpx;
}

.route-tree-track {
  display: flex;
  position: relative;
  width: 72rpx;
  flex-direction: column;
  align-items: center;
}

.route-tree-dot {
  display: flex;
  z-index: 1;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin-top: var(--space-sm);
  border-radius: 50%;
  background: var(--color-primary);
  color: var(--color-surface);
  font-size: 23rpx;
  font-weight: var(--weight-heading);
}

.route-tree-line {
  position: absolute;
  top: 64rpx;
  bottom: -18rpx;
  width: 5rpx;
  background: #f0c9a8;
}

.route-tree-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  padding: var(--space-sm) 0 var(--space-sm) var(--space-sm);
  border-bottom: 2rpx solid var(--color-border);
}

.route-tree-type {
  color: #a65e28;
  font-size: var(--font-xs);
  font-weight: var(--weight-body);
}

.route-tree-action {
  margin-top: var(--space-xs);
  color: var(--color-text-primary);
  font-size: var(--font-base);
  font-weight: var(--weight-heading);
}

.loading-card {
  color: var(--color-text-secondary);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
  text-align: center;
}

.summary-card {
  background: var(--color-primary-light);
}

.simulator-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  margin-top: var(--space-md);
  padding-top: 0;
  padding-bottom: 0;
  border: 3rpx dashed var(--color-primary);
  border-radius: var(--radius-md);
  background: var(--color-surface);
  color: var(--color-primary-dark);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
  line-height: 1.2;
}

.review-center-entry {
  border-style: solid;
  background: var(--color-bg);
}

.route-title {
  margin-top: var(--space-xs);
  color: var(--color-text-primary);
  font-size: 48rpx;
  font-weight: var(--weight-heading);
}

.route-place,
.status-line,
.summary-copy {
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
  line-height: 1.5;
}

.summary-grid {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.summary-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  padding: var(--space-md) var(--space-xs);
  border-radius: var(--radius-md);
  background: var(--color-surface);
}

.summary-value {
  color: var(--color-text-primary);
  font-size: 42rpx;
  font-weight: var(--weight-heading);
}

.summary-label {
  margin-top: var(--space-xs);
  color: #765b45;
  font-size: var(--font-xs);
  font-weight: var(--weight-body);
}

.step-head {
  display: flex;
  align-items: center;
}

.step-heading-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
}

.step-type {
  margin-top: var(--space-xs);
  color: #75685d;
  font-size: var(--font-xs);
  font-weight: var(--weight-body);
}

.review-state {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-pill);
  font-size: var(--font-xs);
  font-weight: var(--weight-heading);
}

.approved {
  background: #edf5e9;
  color: var(--color-success);
}

.pending {
  background: var(--color-warning-bg);
  color: var(--color-warning-text);
}

.step-photo {
  width: 100%;
  height: 340rpx;
  margin-top: var(--space-md);
  border-radius: var(--radius-md);
}

.photo-review-box {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-sm);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  background: var(--color-bg);
}

.photo-review-box.PASS {
  background: #edf5e9;
}

.photo-review-box.WARNING {
  background: var(--color-warning-bg);
}

.photo-review-box.REJECT {
  background: #fff0ed;
}

.photo-review-title {
  color: var(--color-text-primary);
  font-size: var(--font-base);
  font-weight: var(--weight-heading);
}

.photo-review-copy {
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  line-height: 1.5;
}

.blocking-box,
.voice-box,
.transit-copy {
  margin-top: var(--space-md);
  padding: var(--space-md);
  border-radius: var(--radius-md);
}

.blocking-box {
  display: flex;
  flex-direction: column;
  background: var(--color-warning-bg);
}

.blocking-title {
  color: #945817;
  font-size: var(--font-base);
  font-weight: var(--weight-body);
}

.blocking-copy {
  margin-top: var(--space-xs);
  color: #72512f;
  font-size: var(--font-sm);
  line-height: 1.5;
}

.voice-box {
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
}

.voice-label {
  margin-top: var(--space-xs);
  color: var(--color-primary-dark);
  font-size: var(--font-xs);
  font-weight: var(--weight-body);
}

.voice-copy {
  margin-top: var(--space-xs);
  color: #4f463f;
  font-size: var(--font-base);
  line-height: 1.5;
}

.voice-expand-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 82rpx;
  margin-top: var(--space-sm);
  padding-top: 0;
  padding-bottom: 0;
  border: 2rpx solid var(--color-primary);
  border-radius: 18rpx;
  background: var(--color-surface);
  color: var(--color-primary-dark);
  font-size: var(--font-sm);
  font-weight: var(--weight-body);
}

.voice-moment {
  margin-top: var(--space-sm);
  padding-top: var(--space-sm);
  border-top: 2rpx solid #f0e5da;
}

.landmark-box {
  margin-top: var(--space-md);
}

.landmark-input {
  height: 76rpx;
  margin-top: var(--space-xs);
  padding: 0 18rpx;
  border: 2rpx solid #ead8c7;
  border-radius: var(--radius-sm);
  background: var(--color-bg);
  color: var(--color-text-primary);
  font-size: var(--font-base);
}

.voice-status-row {
  display: flex;
  flex-direction: column;
  padding-bottom: var(--space-sm);
  border-bottom: 2rpx solid #f0e5da;
}

.voice-status-title {
  color: var(--color-text-primary);
  font-size: var(--font-md);
  font-weight: var(--weight-heading);
}

.voice-status {
  margin-top: var(--space-xs);
  color: #75685d;
  font-size: var(--font-xs);
  font-weight: var(--weight-body);
}

.voice-custom {
  color: var(--color-success);
}

.voice-actions {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}

.voice-play-button,
.voice-delete-button,
.tts-button,
.record-button,
.record-stop-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding-top: 0;
  padding-bottom: 0;
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
  line-height: 1.2;
}

.voice-play-button {
  flex: 1;
  background: var(--color-surface);
  color: var(--color-primary-dark);
  border: 3rpx solid var(--color-primary);
}

.voice-delete-button {
  width: 150rpx;
  background: #fff0ed;
  color: #a43e32;
}

.record-button,
.tts-button,
.record-stop-button {
  width: 100%;
  margin-top: var(--space-sm);
}

.record-button {
  background: var(--color-primary);
  color: var(--color-surface);
}

.tts-button {
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
}

.record-stop-button {
  background: #c94b3c;
  color: var(--color-surface);
}

.transit-copy {
  background: #f7f2ed;
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-body);
}

.photo-button,
.approve-button,
.reject-button,
.publish-button,
.sticky-photo-button,
.sticky-approve-button,
.sticky-reject-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding-top: 0;
  padding-bottom: 0;
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
  line-height: 1.2;
}

.photo-button {
  margin-top: var(--space-md);
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
}

.review-actions {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}

.approve-button,
.reject-button {
  flex: 1;
}

.approve-button {
  background: var(--color-primary);
  color: var(--color-surface);
}

.reject-button {
  background: #f4efea;
  color: #775f4d;
}

.publish-button {
  width: 100%;
  min-height: 112rpx;
  margin-top: var(--space-md);
  background: var(--color-primary);
  color: var(--color-surface);
  font-size: var(--font-md);
}

.sticky-review-actions {
  position: fixed;
  z-index: 30;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr 0.9fr;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-lg) calc(var(--space-sm) + env(safe-area-inset-bottom));
  border-top: 2rpx solid #ead8c7;
  background: rgba(255, 250, 245, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(90, 58, 32, 0.08);
}

.sticky-photo-button,
.sticky-approve-button,
.sticky-reject-button {
  min-height: 88rpx;
  margin: 0;
  font-size: var(--font-base);
}

.sticky-photo-button {
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
}

.sticky-approve-button {
  background: var(--color-primary);
  color: var(--color-surface);
}

.sticky-reject-button {
  background: #f4efea;
  color: #775f4d;
}

.published-note {
  padding: var(--space-lg);
  border-radius: var(--radius-md);
  background: #edf5e9;
  color: var(--color-success);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
  text-align: center;
}

.ai-action-row {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}

.ai-action-button {
  flex: 1;
  min-height: 92rpx;
  margin: 0;
  background: var(--color-primary);
  color: var(--color-surface);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
  line-height: 1.2;
}

.ai-action-secondary {
  border: 2rpx solid var(--color-primary);
  background: var(--color-surface);
  color: var(--color-primary-dark);
}

.collection-action-button {
  width: 100%;
  flex: none;
}

.collection-card {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-md);
  padding: var(--space-md);
  border: 2rpx solid #f0d7bf;
  border-radius: var(--radius-md);
  background: var(--color-surface);
}

.collection-title {
  color: var(--color-text-primary);
  font-size: var(--font-md);
  font-weight: var(--weight-heading);
}

.collection-summary {
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-body);
  line-height: 1.5;
}

.collection-mini-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-xs);
  margin-top: var(--space-sm);
}

.collection-mini-grid text {
  padding: var(--space-sm) var(--space-xs);
  border-radius: 14rpx;
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  font-size: var(--font-xs);
  font-weight: var(--weight-body);
  text-align: center;
}

.collection-step-box {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-md);
  padding: var(--space-md);
  border: 2rpx solid #f0d7bf;
  border-radius: var(--radius-md);
  background: var(--color-bg);
}

.collection-section {
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 2rpx solid #f2e4d7;
}

.collection-section-title {
  color: var(--color-primary-dark);
  font-size: var(--font-md);
  font-weight: var(--weight-heading);
}

.collection-subtitle {
  color: var(--color-text-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-heading);
}

.collection-task {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-sm);
  padding: var(--space-md);
  border-radius: 18rpx;
  background: var(--color-bg);
}

.collection-task-title {
  color: var(--color-text-primary);
  font-size: var(--font-base);
  font-weight: var(--weight-heading);
}

.collection-copy,
.collection-muted,
.collection-script {
  margin-top: var(--space-xs);
  font-size: var(--font-sm);
  line-height: 1.5;
}

.collection-copy {
  color: #5d5148;
}

.collection-muted {
  color: #7c6f65;
}

.collection-script {
  padding: var(--space-sm);
  border-radius: 14rpx;
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  font-weight: var(--weight-heading);
}

.voice-edit-input {
  width: 100%;
  min-height: 150rpx;
  margin-top: var(--space-xs);
  padding: var(--space-sm);
  border: 2rpx solid #eadbcd;
  border-radius: var(--radius-sm);
  background: var(--color-surface);
  color: #332c27;
  font-size: var(--font-sm);
  line-height: 1.5;
}

.ai-suggestion-box {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-sm);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  background: #fff4e8;
}

.ai-suggestion-title {
  color: var(--color-primary-dark);
  font-size: var(--font-base);
  font-weight: var(--weight-heading);
}

.ai-suggestion-copy {
  margin-top: var(--space-xs);
  color: #65584e;
  font-size: var(--font-sm);
  line-height: 1.5;
}
