<view class="page">
  <view class="summary-card">
    <text class="eyebrow">家庭安全设置</text>
    <text class="summary-title">家路通配置</text>
    <text class="summary-note">先确认求助联系人，再管理家人路线。</text>
  </view>

  <view class="config-section contact-section">
    <view class="card-heading-row">
      <view class="card-heading-copy">
        <text class="settings-title">求助联系人</text>
        <text class="settings-note">{{contactSummary}}</text>
      </view>
      <text class="{{contactReady ? 'status-pill ready-pill' : 'status-pill warning-pill'}}">
        {{contactReady ? "已设置" : "待填写"}}
      </text>
    </view>
    <view class="contact-warning" wx:if="{{contactWarning}}">
      <text>{{contactWarning}}</text>
    </view>
    <button class="contact-entry-button" bindtap="openContactSettings">
      {{contactReady ? "修改求助联系人" : "配置求助联系人"}}
    </button>
  </view>

  <view class="config-section route-section">
    <view class="card-heading-row">
      <view class="card-heading-copy">
        <text class="settings-title">路线管理</text>
        <text class="settings-note">创建路线、审核步骤、补照片和语音。</text>
      </view>
      <text class="{{authUser ? 'status-pill ready-pill' : 'status-pill warning-pill'}}">
        {{authUser ? "已登录" : "未登录"}}
      </text>
    </view>

    <view wx:if="{{authUser}}" class="account-summary">
      <view>
        <text class="account-label">当前家庭</text>
        <text class="account-name">{{authUser.familyName}}</text>
        <text class="account-note">登录身份：{{authUser.displayName || "微信用户"}}</text>
      </view>
      <button class="logout-button" bindtap="logoutFamily">退出</button>
    </view>

    <view wx:else class="login-inline">
      <text class="account-note">登录后才能创建、审核和发布路线。</text>
      <button class="login-button" bindtap="openFamilyLogin">登录或创建账号</button>
    </view>

    <view class="elder-list" wx:if="{{authUser && elders.length}}">
      <text class="account-label">照顾对象</text>
      <view class="elder-row" wx:for="{{elders}}" wx:key="id">
        <view class="elder-info">
          <text class="elder-name">{{item.name}}</text>
          <text class="elder-relation">{{item.relation || "家人"}}</text>
        </view>
        <button class="bind-code-button" data-id="{{item.id}}" bindtap="generateElderBindCode">生成绑定码</button>
      </view>
    </view>

    <button class="route-create-entry" bindtap="openRouteManager">进入路线管理</button>
  </view>

  <view wx:if="{{authUser && arrivalNotifications.length}}" class="config-section arrival-section">
    <view class="card-heading-row">
      <view class="card-heading-copy">
        <text class="settings-title">到达通知</text>
        <text class="settings-note">老人完成路线后，这里会提醒家属确认。</text>
      </view>
      <text class="status-pill warning-pill">{{arrivalNotifications.length}} 条</text>
    </view>
    <view wx:for="{{arrivalNotifications}}" wx:key="id" class="arrival-notice">
      <text class="arrival-title">已到达：{{item.destinationText}}</text>
      <text class="arrival-meta">{{item.routeName}} · 第 {{item.stepNo}} 步</text>
      <text class="arrival-meta">{{item.occurredAt}}</text>
      <text class="arrival-meta">{{item.contactText}}</text>
      <button
        class="arrival-confirm-button"
        loading="{{confirmingArrivalId === item.id}}"
        disabled="{{!!confirmingArrivalId}}"
        data-route-id="{{item.routeId}}"
        data-id="{{item.id}}"
        bindtap="acknowledgeArrival"
      >我知道了</button>
    </view>
  </view>

  <view wx:if="{{bindCodePanel}}" class="bind-code-overlay">
    <view class="bind-code-card">
      <text class="bind-title">{{bindCodePanel.elderName}}的绑定码</text>
      <text class="bind-note">老人手机打开“老人绑定”，点“扫码绑定”。</text>
      <view class="barcode-box">
        <view
          wx:for="{{bindCodePanel.bars}}"
          wx:key="key"
          class="barcode-bar"
          style="width: {{item.width}}rpx; background: {{item.black ? '#111111' : '#ffffff'}};"
        />
      </view>
      <text class="bind-code-text">{{bindCodePanel.code}}</text>
      <text class="bind-expire">30 分钟内有效</text>
      <button class="close-bind-button" bindtap="closeBindCodePanel">关闭</button>
    </view>
  </view>
</view>
