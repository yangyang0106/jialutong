<view class="page">
  <view class="summary-card">
    <text class="eyebrow">家属使用</text>
    <text class="summary-title">家属配置</text>
    <text class="summary-note">路线创建、审核和照片语音配置统一放在路线管理中。</text>
    <view class="account-panel" wx:if="{{authUser}}">
      <text class="account-label">当前家庭</text>
      <text class="account-name">{{authUser.familyName}}</text>
      <text class="account-note">登录身份：{{authUser.displayName || "微信家属"}}</text>
      <view class="elder-list" wx:if="{{elders.length}}">
        <text class="account-label">当前照顾对象</text>
        <view class="elder-pill" wx:for="{{elders}}" wx:key="id">
          <view class="elder-info">
            <text>{{item.name}}</text>
            <text class="elder-relation">{{item.relation}}</text>
          </view>
          <button class="bind-code-button" data-id="{{item.id}}" bindtap="generateElderBindCode">生成绑定码</button>
        </view>
      </view>
      <button class="logout-button" bindtap="logoutFamily">退出账号</button>
    </view>
    <view class="account-panel account-missing" wx:else>
      <text class="account-name">还未登录家属账号</text>
      <text class="account-note">登录后才能创建、审核和发布路线。</text>
      <button class="login-button" bindtap="openFamilyLogin">登录或创建账号</button>
    </view>
    <button class="route-create-entry" bindtap="openRouteManager">进入路线管理</button>
  </view>

  <view class="settings-card">
    <text class="settings-title">求助联系人</text>
    <text class="settings-note">这里填写老人找不到路时可以联系的人。发布前不要使用测试号码。</text>
    <text class="field-label">家属电话</text>
    <input class="field-input" type="number" value="{{familyPhone}}" data-field="familyPhone" bindblur="savePhone" />
    <text class="field-label">紧急联系人姓名</text>
    <input class="field-input" value="{{emergencyContactName}}" placeholder="例如：女儿小王" data-field="emergencyContactName" bindblur="savePhone" />
    <text class="field-label">与老人的关系</text>
    <input class="field-input" value="{{emergencyRelation}}" placeholder="例如：女儿、儿子、邻居" data-field="emergencyRelation" bindblur="savePhone" />
    <text class="field-label">紧急求助电话</text>
    <input class="field-input" type="number" value="{{emergencyPhone}}" data-field="emergencyPhone" bindblur="savePhone" />
  </view>
</view>
