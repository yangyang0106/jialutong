<view class="page">
  <view class="summary-card">
    <text class="eyebrow">家庭安全设置</text>
    <text class="summary-title">家路通配置</text>
    <text class="summary-note">先确认求助联系人，再管理家人路线。</text>
  </view>

  <view class="settings-card contact-card">
    <view class="card-heading-row">
      <view class="card-heading-copy">
        <text class="settings-title">求助联系人</text>
        <text class="settings-note">{{contactSummary}}</text>
      </view>
      <text class="{{contactReady ? 'status-pill ready-pill' : 'status-pill warning-pill'}}">
        {{contactReady ? "已设置" : "待填写"}}
      </text>
    </view>
    <view class="contact-warning" wx:if="{{contactWarning}}">
      <text>{{contactWarning}}</text>
    </view>
    <button class="contact-entry-button" bindtap="openContactSettings">
      {{contactReady ? "修改求助联系人" : "配置求助联系人"}}
    </button>
  </view>

  <view class="settings-card route-admin-card">
    <text class="settings-title">路线管理</text>
    <text class="settings-note">路线创建、审核、照片和语音配置都放在这里。</text>
    <view class="account-panel" wx:if="{{authUser}}">
      <text class="account-label">当前家庭</text>
      <text class="account-name">{{authUser.familyName}}</text>
      <text class="account-note">登录身份：{{authUser.displayName || "微信家属"}}</text>
      <view class="elder-list" wx:if="{{elders.length}}">
        <text class="account-label">当前照顾对象</text>
        <view class="elder-pill" wx:for="{{elders}}" wx:key="id">
          <view class="elder-info">
            <text>{{item.name}}</text>
            <text class="elder-relation">{{item.relation}}</text>
          </view>
          <button class="bind-code-button" data-id="{{item.id}}" bindtap="generateElderBindCode">生成绑定码</button>
        </view>
      </view>
      <button class="logout-button" bindtap="logoutFamily">退出账号</button>
    </view>
    <view class="account-panel account-missing" wx:else>
      <text class="account-name">还未登录家属账号</text>
      <text class="account-note">登录后才能创建、审核和发布路线。</text>
      <button class="login-button" bindtap="openFamilyLogin">登录或创建账号</button>
    </view>
    <button class="route-create-entry" bindtap="openRouteManager">进入路线管理</button>
  </view>
</view>
