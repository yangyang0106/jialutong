/* config 页面 - 家属配置 */
.page {
  min-height: 100vh;
  padding: var(--space-lg);
  background: var(--color-bg);
}

.summary-card,
.step-card,
.settings-card,
.config-section {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--space-md);
  padding: var(--space-lg);
  border: 3rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.settings-title {
  margin-bottom: var(--space-xs);
  color: var(--color-text-primary);
  font-size: var(--font-xl);
  font-weight: var(--weight-heading);
}

.settings-note {
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  line-height: 1.5;
}

.card-heading-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-md);
}

.card-heading-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
}

.status-pill {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-xs);
  font-weight: var(--weight-label);
}

.ready-pill {
  background: #fff2dc;
  color: #9a5c13;
}

.warning-pill {
  background: #ffe9e2;
  color: #a53325;
}

.contact-card {
  border-color: #ffd0a6;
  background: #fffdfb;
}

.contact-section {
  border-color: #ffd0a6;
  background: #fffdfb;
}

.route-section {
  background: var(--color-surface);
}

.arrival-section {
  border-color: #cfe7c0;
  background: #f8fff4;
}

.arrival-notice {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-md);
  padding: var(--space-md);
  border: 2rpx solid #cfe7c0;
  border-radius: var(--radius-md);
  background: var(--color-surface);
}

.arrival-title {
  color: var(--color-text-primary);
  font-size: var(--font-md);
  font-weight: var(--weight-heading);
}

.arrival-meta {
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  line-height: 1.45;
}

button.arrival-confirm-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  margin-top: var(--space-md);
  border-radius: var(--radius-md);
  background: var(--color-primary);
  color: #ffffff;
  font-size: var(--font-base);
  font-weight: var(--weight-heading);
}

.contact-warning {
  margin-top: var(--space-md);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  background: #fff2dc;
  color: #8a5a24;
  font-size: var(--font-sm);
  font-weight: var(--weight-body);
  line-height: 1.45;
}

button.contact-entry-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  margin-top: var(--space-md);
  padding: 0 var(--space-md);
  border: 3rpx solid #efb57e;
  border-radius: var(--radius-md);
  background: #fff8f1;
  color: var(--color-primary-dark);
  font-size: var(--font-md);
  font-weight: var(--weight-heading);
  line-height: 1.2;
}

.bind-code-overlay {
  position: fixed;
  z-index: 80;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  background: rgba(47, 36, 28, 0.68);
}

.bind-code-card {
  display: flex;
  flex-direction: column;
  width: 100%;
  padding: var(--space-xl) var(--space-lg);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  text-align: center;
}

.bind-title {
  color: var(--color-text-primary);
  font-size: var(--font-2xl);
  font-weight: var(--weight-heading);
}

.bind-note,
.bind-expire {
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
  font-size: var(--font-base);
  line-height: 1.45;
}

.barcode-box {
  display: flex;
  align-items: stretch;
  justify-content: center;
  height: 170rpx;
  margin-top: var(--space-lg);
  padding: var(--space-md);
  border: 3rpx solid #111111;
  border-radius: var(--radius-sm);
  background: #ffffff;
}

.barcode-bar {
  height: 100%;
}

.bind-code-text {
  margin-top: var(--space-md);
  color: var(--color-text-primary);
  font-size: 64rpx;
  font-weight: var(--weight-heading);
  letter-spacing: 8rpx;
}

.close-bind-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100rpx;
  margin-top: var(--space-lg);
  border-radius: var(--radius-md);
  background: var(--color-primary);
  color: var(--color-surface);
  font-size: var(--font-md);
  font-weight: var(--weight-heading);
}

.field-label {
  margin-top: var(--space-md);
  margin-bottom: var(--space-xs);
  color: var(--color-text-secondary);
  font-size: var(--font-base);
  font-weight: var(--weight-label);
}

.field-input,
.coordinate-input {
  border: 3rpx solid #eadbcd;
  border-radius: var(--radius-md);
  background: #fffdfb;
  color: var(--color-text-primary);
  font-size: var(--font-md);
}

.field-input,
.coordinate-input {
  height: 84rpx;
  padding: 0 var(--space-md);
}

.coordinate-row {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}

.coordinate-input {
  flex: 1;
  width: 0;
}

.verify-check {
  display: flex;
  align-items: center;
  margin-top: var(--space-md);
  padding: var(--space-md);
  border-radius: 18rpx;
  background: #fff2e5;
  color: var(--color-primary-dark);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
}

.issues {
  margin-top: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  background: #fff2dc;
  color: #9a5c13;
  font-size: var(--font-sm);
  font-weight: var(--weight-body);
}

.required-issues {
  background: var(--color-warning-bg);
  color: var(--color-warning-text);
}

.optional-issues {
  background: #f7f2ed;
  color: var(--color-text-secondary);
}

.summary-card {
  background: var(--color-primary-light);
  box-shadow: none;
}

.summary-title {
  margin-top: var(--space-xs);
  font-size: 50rpx;
  font-weight: var(--weight-heading);
}

.stat-grid {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
}

.stat-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  padding: var(--space-md) var(--space-xs);
  border-radius: var(--radius-md);
  background: var(--color-surface);
}

.warning-stat {
  background: #fff8f1;
}

.required-stat {
  background: #ffe7d0;
}

.stat-value {
  font-size: 46rpx;
  font-weight: var(--weight-heading);
}

.stat-label {
  margin-top: var(--space-xs);
  font-size: var(--font-xs);
  font-weight: var(--weight-label);
}

.summary-note {
  margin-top: var(--space-lg);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
  line-height: 1.55;
  color: var(--color-text-secondary);
}

.account-summary,
.login-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  margin-top: var(--space-md);
}

.account-label,
.account-note {
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-body);
}

.account-name {
  display: block;
  margin-top: var(--space-xs);
  color: var(--color-text-primary);
  font-size: var(--font-md);
  font-weight: var(--weight-heading);
}

.elder-list {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-md);
}

.elder-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  min-height: 96rpx;
  margin-top: var(--space-sm);
  padding: var(--space-sm) 0;
  border-top: 2rpx solid #f0e5da;
  color: var(--color-text-primary);
  font-size: var(--font-base);
  font-weight: var(--weight-label);
}

.elder-info {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
}

.elder-name {
  color: var(--color-text-primary);
  font-size: var(--font-base);
  font-weight: var(--weight-heading);
}

.elder-relation {
  color: var(--color-primary-dark);
  font-size: var(--font-sm);
}

button.login-button,
button.logout-button,
button.bind-code-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  padding: 0 var(--space-md);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  font-weight: var(--weight-label);
  line-height: 1.2;
}

button.login-button {
  flex-shrink: 0;
  background: var(--color-primary);
  color: #ffffff;
}

button.logout-button {
  flex-shrink: 0;
  border: 3rpx solid #efb57e;
  background: #fff8f1;
  color: var(--color-primary-dark);
}

button.bind-code-button {
  flex-shrink: 0;
  min-height: 76rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  font-size: var(--font-sm);
}

.optional-note {
  margin-top: var(--space-xs);
}

button.route-create-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 92rpx;
  margin-top: var(--space-md);
  padding-top: 0;
  padding-bottom: 0;
  border: 3rpx solid #efb57e;
  border-radius: var(--radius-md);
  background: var(--color-surface);
  color: var(--color-primary-dark);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
  line-height: 1.2;
}

.route-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: var(--space-xl) var(--space-xs) var(--space-md);
}

.route-title {
  color: var(--color-text-primary);
  font-size: 44rpx;
  font-weight: var(--weight-heading);
}

.route-count {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-pill);
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  font-size: var(--font-sm);
  font-weight: var(--weight-label);
}

button.route-missing-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-height: 68rpx;
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-warning-bg);
  color: var(--color-warning-text);
  font-size: var(--font-xs);
  font-weight: var(--weight-label);
}

.route-ready {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-pill);
  background: var(--color-primary-light);
  color: #8a5a24;
  font-size: var(--font-xs);
  font-weight: var(--weight-label);
}

.target-step {
  box-shadow: 0 0 0 6rpx #ef9a4c, 0 12rpx 28rpx rgba(74, 47, 27, 0.1);
}

.step-heading {
  display: flex;
  align-items: center;
}

.step-title {
  flex: 1;
  color: var(--color-text-primary);
  font-size: var(--font-lg);
  font-weight: var(--weight-heading);
  line-height: 1.35;
}

.step-desc {
  margin: var(--space-md) 0 var(--space-md);
  color: var(--color-text-secondary);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
  line-height: 1.55;
}

.preview {
  width: 100%;
  height: 340rpx;
  margin-bottom: var(--space-xs);
  border-radius: var(--radius-md);
}

/* 页面内按钮 — 不使用裸 button 选择器 */
.step-card button {
  width: 100%;
  margin-top: var(--space-sm);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
}

.asset-button,
.play-button,
.location-button,
.delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 0;
  padding-bottom: 0;
}

.asset-button {
  min-height: 98rpx;
  color: var(--color-surface);
}

.image-button {
  background: var(--color-primary);
}

.audio-button,
.play-button,
.location-button {
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
}

.recording-button {
  background: #d94c4c;
  color: var(--color-surface);
}

.delete-button {
  background: transparent;
  color: #b04b4b;
}


.elder-pill {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
}

.elder-info {
  display: flex;
  flex: 1;
  flex-direction: column;
}

.bind-code-button {
  min-height: 72rpx;
  padding: 0 var(--space-md);
  border-radius: 999rpx;
  background: #fff2e5;
  color: var(--color-primary-dark);
  font-size: var(--font-sm);
  font-weight: var(--weight-heading);
}
