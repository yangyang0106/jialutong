.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx;
  background: #f2f7f7;
}

.summary-card,
.step-card,
.settings-card {
  display: flex;
  flex-direction: column;
  margin-bottom: 26rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(23, 69, 73, 0.09);
}

.settings-title {
  margin-bottom: 10rpx;
  color: #173438;
  font-size: 42rpx;
  font-weight: 900;
}

.field-label {
  margin-top: 22rpx;
  margin-bottom: 10rpx;
  color: #48676a;
  font-size: 28rpx;
  font-weight: 800;
}

.field-input,
.field-textarea,
.coordinate-input {
  box-sizing: border-box;
  border: 3rpx solid #d8e7e6;
  border-radius: 20rpx;
  background: #f6faf9;
  color: #173438;
  font-size: 30rpx;
}

.field-input,
.coordinate-input {
  min-height: 84rpx;
  padding: 0 20rpx;
}

.field-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
}

.coordinate-row {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.coordinate-input {
  flex: 1;
  width: 0;
}

.verify-check {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #e9f5f3;
  color: #176b72;
  font-size: 29rpx;
  font-weight: 900;
}

.issues {
  margin-top: 18rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #fff2dc;
  color: #9a5c13;
  font-size: 27rpx;
  font-weight: 900;
}

.summary-card {
  background: linear-gradient(145deg, #176b72, #268a91);
  color: #ffffff;
}

.eyebrow {
  font-size: 25rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  opacity: 0.75;
}

.summary-title {
  margin-top: 10rpx;
  font-size: 50rpx;
  font-weight: 900;
}

.stat-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}

.stat-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  padding: 22rpx 8rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.16);
}

.warning-stat {
  background: rgba(255, 226, 173, 0.2);
}

.stat-value {
  font-size: 46rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.summary-note {
  margin-top: 26rpx;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.55;
  opacity: 0.9;
}

.route-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 44rpx 4rpx 22rpx;
}

.route-title {
  color: #173438;
  font-size: 44rpx;
  font-weight: 900;
}

.route-count {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #d8efed;
  color: #176b72;
  font-size: 27rpx;
  font-weight: 900;
}

.step-heading {
  display: flex;
  align-items: center;
}

.step-number {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-right: 18rpx;
  border-radius: 20rpx;
  background: #176b72;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.step-title {
  flex: 1;
  color: #173438;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.35;
}

.step-desc {
  margin: 20rpx 0 24rpx;
  color: #648084;
  font-size: 29rpx;
  font-weight: 600;
  line-height: 1.55;
}

.preview {
  width: 100%;
  height: 340rpx;
  margin-bottom: 12rpx;
  border-radius: 24rpx;
}

button {
  width: 100%;
  margin-top: 16rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.asset-button {
  min-height: 98rpx;
  color: #ffffff;
}

.image-button {
  background: #176b72;
}

.audio-button,
.play-button,
.location-button {
  background: #e4f1f0;
  color: #176b72;
}

.recording-button {
  background: #d94c4c;
  color: #ffffff;
}

.delete-button {
  background: transparent;
  color: #b04b4b;
}
