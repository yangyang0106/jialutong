/* config 页面 - 家属配置 */
.page {
  min-height: 100vh;
  padding: var(--space-lg);
  background: var(--color-bg);
}

.summary-card,
.step-card,
.settings-card {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--space-md);
  padding: var(--space-lg);
  border: 3rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.settings-title {
  margin-bottom: var(--space-xs);
  color: var(--color-text-primary);
  font-size: var(--font-xl);
  font-weight: var(--weight-heading);
}

.settings-note {
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  line-height: 1.5;
}

.field-label {
  margin-top: var(--space-md);
  margin-bottom: var(--space-xs);
  color: var(--color-text-secondary);
  font-size: var(--font-base);
  font-weight: var(--weight-label);
}

.field-input,
.coordinate-input {
  border: 3rpx solid #eadbcd;
  border-radius: var(--radius-md);
  background: #fffdfb;
  color: var(--color-text-primary);
  font-size: var(--font-md);
}

.field-input,
.coordinate-input {
  height: 84rpx;
  padding: 0 var(--space-md);
}

.coordinate-row {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}

.coordinate-input {
  flex: 1;
  width: 0;
}

.verify-check {
  display: flex;
  align-items: center;
  margin-top: var(--space-md);
  padding: var(--space-md);
  border-radius: 18rpx;
  background: #fff2e5;
  color: var(--color-primary-dark);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
}

.issues {
  margin-top: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  background: #fff2dc;
  color: #9a5c13;
  font-size: var(--font-sm);
  font-weight: var(--weight-body);
}

.required-issues {
  background: var(--color-warning-bg);
  color: var(--color-warning-text);
}

.optional-issues {
  background: #f7f2ed;
  color: var(--color-text-secondary);
}

.summary-card {
  background: var(--color-primary-light);
  box-shadow: none;
}

.summary-title {
  margin-top: var(--space-xs);
  font-size: 50rpx;
  font-weight: var(--weight-heading);
}

.stat-grid {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
}

.stat-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  padding: var(--space-md) var(--space-xs);
  border-radius: var(--radius-md);
  background: var(--color-surface);
}

.warning-stat {
  background: #fff8f1;
}

.required-stat {
  background: #ffe7d0;
}

.stat-value {
  font-size: 46rpx;
  font-weight: var(--weight-heading);
}

.stat-label {
  margin-top: var(--space-xs);
  font-size: var(--font-xs);
  font-weight: var(--weight-label);
}

.summary-note {
  margin-top: var(--space-lg);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
  line-height: 1.55;
  color: var(--color-text-secondary);
}

.account-panel {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-md);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  background: #fffdfb;
}

.account-missing {
  background: #fff8f1;
}

.account-label,
.account-note {
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
  font-weight: var(--weight-body);
}

.account-name {
  margin-top: var(--space-xs);
  color: var(--color-text-primary);
  font-size: var(--font-md);
  font-weight: var(--weight-heading);
}

.elder-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-top: var(--space-md);
}

.elder-pill {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-primary-light);
  color: var(--color-text-primary);
  font-size: var(--font-base);
  font-weight: var(--weight-label);
}

.elder-relation {
  color: var(--color-primary-dark);
  font-size: var(--font-sm);
}

button.login-button,
button.logout-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  margin-top: var(--space-md);
  padding: 0 var(--space-md);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  font-weight: var(--weight-label);
}

button.login-button {
  background: var(--color-primary);
  color: #ffffff;
}

button.logout-button {
  border: 3rpx solid #efb57e;
  background: #fff8f1;
  color: var(--color-primary-dark);
}

.optional-note {
  margin-top: var(--space-xs);
}

button.route-create-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 92rpx;
  margin-top: var(--space-md);
  padding-top: 0;
  padding-bottom: 0;
  border: 3rpx solid #efb57e;
  border-radius: var(--radius-md);
  background: var(--color-surface);
  color: var(--color-primary-dark);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
}

.route-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: var(--space-xl) var(--space-xs) var(--space-md);
}

.route-title {
  color: var(--color-text-primary);
  font-size: 44rpx;
  font-weight: var(--weight-heading);
}

.route-count {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-pill);
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  font-size: var(--font-sm);
  font-weight: var(--weight-label);
}

button.route-missing-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-height: 68rpx;
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-warning-bg);
  color: var(--color-warning-text);
  font-size: var(--font-xs);
  font-weight: var(--weight-label);
}

.route-ready {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-pill);
  background: var(--color-primary-light);
  color: #8a5a24;
  font-size: var(--font-xs);
  font-weight: var(--weight-label);
}

.target-step {
  box-shadow: 0 0 0 6rpx #ef9a4c, 0 12rpx 28rpx rgba(74, 47, 27, 0.1);
}

.step-heading {
  display: flex;
  align-items: center;
}

.step-title {
  flex: 1;
  color: var(--color-text-primary);
  font-size: var(--font-lg);
  font-weight: var(--weight-heading);
  line-height: 1.35;
}

.step-desc {
  margin: var(--space-md) 0 var(--space-md);
  color: var(--color-text-secondary);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
  line-height: 1.55;
}

.preview {
  width: 100%;
  height: 340rpx;
  margin-bottom: var(--space-xs);
  border-radius: var(--radius-md);
}

/* 页面内按钮 — 不使用裸 button 选择器 */
.step-card button {
  width: 100%;
  margin-top: var(--space-sm);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
}

.asset-button,
.play-button,
.location-button,
.delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 0;
  padding-bottom: 0;
}

.asset-button {
  min-height: 98rpx;
  color: var(--color-surface);
}

.image-button {
  background: var(--color-primary);
}

.audio-button,
.play-button,
.location-button {
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
}

.recording-button {
  background: #d94c4c;
  color: var(--color-surface);
}

.delete-button {
  background: transparent;
  color: #b04b4b;
}


.elder-pill {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
}

.elder-info {
  display: flex;
  flex: 1;
  flex-direction: column;
}

.bind-code-button {
  min-height: 72rpx;
  padding: 0 var(--space-md);
  border-radius: 999rpx;
  background: #fff2e5;
  color: var(--color-primary-dark);
  font-size: var(--font-sm);
  font-weight: var(--weight-heading);
}
