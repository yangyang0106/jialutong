/* route 页面 - 老年人导航视图 */
.elder-page {
  min-height: 100vh;
  padding: 190rpx var(--space-md) calc(320rpx + env(safe-area-inset-bottom));
  background: var(--color-surface);
}

.elder-header {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  min-height: 166rpx;
  padding: var(--space-sm) 28rpx;
  border-bottom: 3rpx solid #f3e5d7;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.header-line,
.header-meta {
  display: flex;
  align-items: center;
}

.header-label {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-pill);
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
}

.header-main {
  margin-left: var(--space-sm);
  color: var(--color-text-primary);
  font-size: var(--font-xl);
  font-weight: var(--weight-heading);
}

.header-meta {
  justify-content: space-between;
  margin-top: var(--space-sm);
  color: #574b42;
  font-size: var(--font-base);
  font-weight: var(--weight-body);
}

.demo-warning {
  margin-bottom: var(--space-sm);
  padding: var(--space-sm);
  border-radius: var(--radius-md);
  background: #fff4e7;
  color: var(--color-primary-dark);
  font-size: var(--font-base);
  font-weight: var(--weight-heading);
  text-align: center;
}

.target-card {
  position: relative;
  overflow: hidden;
  min-height: 55vh;
  border: 3rpx solid #f1e4d7;
  border-radius: var(--radius-lg);
  background: #fff8f1;
  box-shadow: var(--shadow-elevated);
}

.target-photo,
.target-placeholder {
  width: 100%;
  height: 55vh;
  min-height: 590rpx;
}

.target-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-lg);
  padding: var(--space-xl);
  background: #fff8f1;
  color: #4e4137;
  font-size: var(--font-xl);
  font-weight: var(--weight-heading);
  text-align: center;
}

.placeholder-title {
  color: var(--color-text-primary);
  font-size: var(--font-3xl);
  font-weight: var(--weight-heading);
}

.placeholder-copy {
  color: #76675a;
  font-size: var(--font-md);
  font-weight: var(--weight-body);
}

.direction-badge {
  position: absolute;
  right: var(--space-md);
  bottom: var(--space-md);
  max-width: 72%;
  padding: 20rpx 34rpx;
  border: 7rpx solid var(--color-surface);
  border-radius: var(--radius-md);
  background: #ef7f32;
  color: var(--color-surface);
  font-size: 66rpx;
  font-weight: var(--weight-heading);
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(196, 99, 28, 0.28);
}

.task-card,
.finished-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: var(--space-sm);
  padding: var(--space-xl) 26rpx;
  border: 3rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  text-align: center;
}

.task-label {
  color: #8f725c;
  font-size: var(--font-base);
  font-weight: var(--weight-body);
}

.task-text,
.finished-title {
  margin-top: var(--space-xs);
  color: var(--color-text-primary);
  font-size: 66rpx;
  font-weight: var(--weight-heading);
  line-height: 1.2;
}

.step-title {
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
}

.voice-first,
.help-hint,
.finished-desc {
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
}

.voice-first {
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
}

.audio-status {
  margin-top: var(--space-sm);
  color: var(--color-primary-dark);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
}

.nearby,
.stop-warning,
.voice-warning,
.risk-reminder {
  margin-top: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
}

.risk-reminder {
  background: var(--color-warning-bg);
  color: var(--color-warning-text);
}

.nearby {
  background: #fff3e6;
  color: var(--color-primary-dark);
}

.voice-fallback {
  display: flex;
  flex-direction: column;
  margin-top: var(--space-md);
  padding: var(--space-md);
  border-radius: var(--radius-md);
  background: #fff8f1;
  color: #4e4137;
  font-size: var(--font-md);
  font-weight: var(--weight-body);
  line-height: 1.55;
}

.fallback-hint {
  margin-top: var(--space-sm);
  color: var(--color-primary-dark);
}

.arrival-box {
  display: flex;
  flex-direction: column;
  width: 100%;
  margin-top: var(--space-md);
  padding: var(--space-md);
  border-radius: 22rpx;
  background: #fff3e6;
}

.not-found-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 100rpx;
  margin-top: var(--space-sm);
  padding-top: 0;
  padding-bottom: 0;
  border-radius: var(--radius-md);
  background: var(--color-surface);
  color: #6a5544;
  font-size: var(--font-md);
  font-weight: var(--weight-body);
}

.stop-warning,
.voice-warning {
  background: #ffe7e4;
  color: #a52f2f;
}

.elder-actions {
  position: fixed;
  z-index: 30;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-sm);
  padding: var(--space-md) var(--space-md) calc(30rpx + env(safe-area-inset-bottom));
  border-top: 3rpx solid #f1e5da;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(74, 47, 27, 0.08);
}

.elder-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 120rpx;
  border-radius: var(--radius-md);
  font-size: 39rpx;
  font-weight: var(--weight-heading);
  padding-top: 0;
  padding-bottom: 0;
}

.voice-button {
  background: #fff3e6;
  color: #9a5624;
  box-shadow: inset 0 0 0 4rpx #f3c89e;
}

.next-button {
  background: var(--color-primary);
  color: var(--color-surface);
}

.finished-button {
  grid-column: 1 / -1;
}

.help-button,
.emergency-button {
  background: var(--color-danger);
  color: var(--color-surface);
}

.help-button {
  grid-column: 1 / -1;
}

.help-holding {
  background: #b8322c;
  box-shadow: inset 0 0 0 8rpx #ffd0cc;
}

.help-overlay {
  position: fixed;
  z-index: 100;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  background: rgba(47, 36, 28, 0.72);
}

.help-card {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-height: 92vh;
  gap: var(--space-sm);
  overflow-y: auto;
  padding: var(--space-xl);
  border-radius: 36rpx;
  background: var(--color-surface);
  animation: fadeIn 0.25s ease;
}

.stop-title,
.help-title {
  margin-bottom: var(--space-xs);
  color: #bd3e38;
  font-size: 58rpx;
  font-weight: var(--weight-heading);
  text-align: center;
}

.help-line {
  color: #292522;
  font-size: 38rpx;
  font-weight: var(--weight-heading);
  line-height: 1.5;
}

.resume,
.close-help {
  background: #72645a;
  color: var(--color-surface);
}

.simulator-panel {
  margin-top: var(--space-sm);
  padding: var(--space-md);
  border: 3rpx dashed var(--color-primary);
  border-radius: var(--radius-md);
  background: #fff8f1;
}

.simulator-title {
  color: var(--color-primary-dark);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
}

.simulator-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xs);
  margin-top: var(--space-sm);
}

.simulator-actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  margin: 0;
  padding-top: 0;
  padding-bottom: 0;
  border-radius: 18rpx;
  background: var(--color-surface);
  color: var(--color-primary-dark);
  font-size: var(--font-xs);
  font-weight: var(--weight-body);
}
