<!--index/index.wxml-->
<view class="page">
  <view class="hero">
    <view class="brand-mark">家</view>
    <text class="title">家路通</text>
    <text class="subtitle">家人陪你安心出门</text>
  </view>

  <!-- 未登录：选择身份 -->
  <block wx:if="{{isGuest}}">
    <view class="guest-card animate-fade-in">
      <text class="guest-title">今天要去哪里？</text>
      <text class="guest-note">请选择您的身份开始使用</text>
      <button class="guest-family-button" bindtap="openFamilyLogin" hover-class="button-hover">家属登录</button>
      <button class="guest-elder-button" bindtap="openElderBind" hover-class="button-hover">老人绑定家路通</button>
    </view>
  </block>

  <!-- 老人 & 家属：显示路线 -->
  <block wx:if="{{hasActiveRole}}">
    <text class="question">{{questionText}}</text>

    <!-- 加载中 -->
    <view wx:if="{{showLoading}}" class="loading-state">
      <text class="loading-text">正在加载路线...</text>
    </view>

    <!-- 路线列表 -->
    <view class="route-list" wx:if="{{hasRoutes}}">
      <button wx:for="{{routeCards}}" wx:key="routeId" class="route-card" data-route-id="{{item.routeId}}" bindtap="goToRoute" hover-class="button-hover">
        <view class="route-icon">{{item.icon}}</view>
        <view class="route-copy">
          <text class="route-label">{{item.name}}</text>
          <text class="route-place">{{item.place}}</text>
          <text class="{{item.statusClass}}">{{item.statusText}}</text>
        </view>
        <text class="route-arrow">›</text>
      </button>
    </view>

    <!-- 空状态 -->
    <view class="empty-state animate-fade-in" wx:if="{{showEmpty}}">
      <view class="empty-state-icon">?</view>
      <text class="empty-state-text">{{emptyText}}</text>
    </view>

    <!-- 老人操作按钮 -->
    <button wx:if="{{isElder}}" class="{{helpButtonClass}}" bindtouchstart="startHelpHold" bindtouchend="cancelHelpHold" bindtouchcancel="cancelHelpHold" hover-class="button-hover">
      {{helpButtonText}}
    </button>

    <!-- 家属操作按钮 -->
    <button wx:if="{{isFamily}}" class="config-button" bindtap="openRouteManager" hover-class="button-hover">创建路线</button>
    <button wx:if="{{isFamily}}" class="config-button" bindtap="openConfig" hover-class="button-hover">家属配置</button>
  </block>
</view>
