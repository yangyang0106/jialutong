<!--index/index.wxml-->
<view class="page">
  <view class="hero">
    <view class="brand-mark">家</view>
    <text class="title">家路通</text>
    <text class="subtitle">家人陪你安心出门</text>
    <text class="question">今天要去哪里？</text>
  </view>

  <view class="route-list" wx:if="{{routeCards.length > 0}}">
    <button wx:for="{{routeCards}}" wx:key="routeId" class="route-card" data-route-id="{{item.routeId}}" bindtap="goToRoute" hover-class="button-hover">
      <view class="route-icon">{{item.icon}}</view>
      <view class="route-copy">
        <text class="route-label">{{item.name}}</text>
        <text class="route-place">{{item.place}}</text>
        <text class="{{item.ready ? 'ready-text' : 'not-ready-text'}}">
          {{item.ready ? "路线已启用" : "点这里补齐 · " + item.issueCount + " 步关键配置"}}
        </text>
      </view>
      <text class="route-arrow">›</text>
    </button>
  </view>

  <!-- 空状态 -->
  <view class="empty-state animate-fade-in" wx:if="{{routeCards.length === 0 && !isLoading}}">
    <view class="empty-state-icon">?</view>
    <text class="empty-state-text">暂无路线，请家属先配置路线</text>
  </view>

  <button class="help-button" bindtap="requestHelp" hover-class="button-hover">紧急求助</button>
  <button class="config-button" bindtap="openConfig" hover-class="button-hover">家属配置</button>
</view>
