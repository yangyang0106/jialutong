/* index 页面 - 首页 */
.page {
  min-height: 100vh;
  padding: 48rpx var(--space-lg) var(--space-xl);
  background: var(--color-surface);
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: var(--space-xl);
  padding: var(--space-xs) var(--space-xs);
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  margin-bottom: var(--space-md);
  border-radius: var(--radius-md);
  background: #f59a45;
  color: var(--color-surface);
  font-size: 58rpx;
  font-weight: var(--weight-heading);
  box-shadow: 0 12rpx 28rpx rgba(224, 125, 42, 0.22);
}

.title {
  color: var(--color-text-primary);
  font-size: 62rpx;
  font-weight: var(--weight-heading);
  letter-spacing: 3rpx;
}

.subtitle {
  margin-top: var(--space-sm);
  color: var(--color-text-secondary);
  font-size: var(--font-base);
  font-weight: var(--weight-body);
}

.question {
  margin-top: var(--space-xl);
  color: var(--color-text-primary);
  font-size: var(--font-xl);
  font-weight: var(--weight-heading);
}

.route-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.route-card {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 184rpx;
  padding: var(--space-lg);
  border: 3rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--color-bg);
  text-align: left;
  box-shadow: var(--shadow-card);
  margin: 0;
}

.route-card::after {
  border: none;
}

.route-icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 98rpx;
  height: 98rpx;
  border-radius: var(--radius-md);
  background: #f59a45;
  color: var(--color-surface);
  font-size: 46rpx;
  font-weight: var(--weight-heading);
}

.home-card .route-icon {
  background: #e98235;
}

.route-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  margin-left: var(--space-md);
}

.route-label {
  color: var(--color-text-primary);
  font-size: var(--font-xl);
  font-weight: var(--weight-heading);
}

.route-place {
  margin-top: var(--space-xs);
  color: var(--color-text-secondary);
  font-size: var(--font-md);
  font-weight: var(--weight-body);
}

.ready-text,
.not-ready-text {
  margin-top: var(--space-xs);
  font-size: var(--font-xs);
  font-weight: var(--weight-label);
}

.ready-text {
  color: var(--color-primary-dark);
}

.not-ready-text {
  color: #8a4518;
}

.route-arrow {
  color: #b9a89a;
  font-size: 70rpx;
}

.help-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 128rpx;
  margin-top: var(--space-xl);
  border-radius: var(--radius-lg);
  background: var(--color-danger);
  color: var(--color-surface);
  font-size: var(--font-xl);
  font-weight: var(--weight-heading);
  padding-top: 0;
  padding-bottom: 0;
}

.config-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 100rpx;
  margin-top: var(--space-md);
  padding-top: 0;
  padding-bottom: 0;
  border-radius: var(--radius-md);
  background: #fff5eb;
  color: #6f4b2d;
  font-size: var(--font-base);
  font-weight: var(--weight-body);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-2xl) var(--space-lg);
  text-align: center;
}

.empty-state-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: var(--space-lg);
  border-radius: 50%;
  background: var(--color-primary-light);
  color: var(--color-primary-dark);
  font-size: 60rpx;
  font-weight: var(--weight-heading);
  line-height: 120rpx;
  text-align: center;
}

.empty-state-text {
  color: var(--color-text-secondary);
  font-size: var(--font-base);
  font-weight: var(--weight-label);
}
