.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 72rpx 32rpx 48rpx;
  background: linear-gradient(180deg, #dff3f1 0%, #f2f7f7 44%, #f2f7f7 100%);
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 58rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 118rpx;
  height: 118rpx;
  margin-bottom: 24rpx;
  border-radius: 36rpx;
  background: #176b72;
  color: #ffffff;
  font-size: 62rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 42rpx rgba(23, 107, 114, 0.25);
}

.title {
  color: #123f44;
  font-size: 64rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.subtitle {
  margin-top: 16rpx;
  color: #557478;
  font-size: 38rpx;
  font-weight: 700;
}

.route-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.route-card {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 180rpx;
  box-sizing: border-box;
  padding: 30rpx;
  border-radius: 34rpx;
  background: #ffffff;
  text-align: left;
  box-shadow: 0 18rpx 46rpx rgba(23, 69, 73, 0.11);
}

.route-icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 98rpx;
  height: 98rpx;
  border-radius: 30rpx;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 900;
}

.mom-card .route-icon {
  background: #ef7f68;
}

.home-card .route-icon {
  background: #268a91;
}

.route-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  margin-left: 28rpx;
}

.route-label {
  color: #173438;
  font-size: 48rpx;
  font-weight: 900;
}

.route-place {
  margin-top: 10rpx;
  color: #668084;
  font-size: 31rpx;
  font-weight: 700;
}

.ready-text,
.not-ready-text {
  margin-top: 10rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.ready-text {
  color: #17815d;
}

.not-ready-text {
  color: #b16c23;
}

.route-arrow {
  color: #9eb0b2;
  font-size: 72rpx;
  font-weight: 400;
}

.help-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 132rpx;
  margin-top: 46rpx;
  border-radius: 32rpx;
  background: #d94c4c;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 36rpx rgba(180, 49, 49, 0.22);
}

.config-button {
  width: 100%;
  min-height: 92rpx;
  margin-top: 24rpx;
  border-radius: 26rpx;
  background: transparent;
  color: #557478;
  font-size: 31rpx;
  font-weight: 800;
}
