/* index 页面 - 首页 */
.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 48rpx;
  background: #ffffff;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 48rpx;
  padding: 8rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #f59a45;
  color: #ffffff;
  font-size: 58rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 28rpx rgba(224, 125, 42, 0.22);
}

.title {
  color: #222222;
  font-size: 62rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
}

.subtitle {
  margin-top: 16rpx;
  color: #5a4e45;
  font-size: 28rpx;
  font-weight: 500;
}

.question {
  margin-top: 48rpx;
  color: #222222;
  font-size: 40rpx;
  font-weight: 900;
}

.route-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.route-card {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 184rpx;
  padding: 32rpx;
  border: 3rpx solid #f1e7dc;
  border-radius: 32rpx;
  background: #fffaf5;
  text-align: left;
  box-shadow: 0 10rpx 26rpx rgba(74, 47, 27, 0.07);
  margin: 0;
}

.route-card::after {
  border: none;
}

.route-icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 98rpx;
  height: 98rpx;
  border-radius: 24rpx;
  background: #f59a45;
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 900;
}

.home-card .route-icon {
  background: #e98235;
}

.route-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  margin-left: 24rpx;
}

.route-label {
  color: #222222;
  font-size: 40rpx;
  font-weight: 900;
}

.route-place {
  margin-top: 8rpx;
  color: #5a4e45;
  font-size: 32rpx;
  font-weight: 500;
}

.ready-text,
.not-ready-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 400;
}

.ready-text {
  color: #96521f;
}

.not-ready-text {
  color: #8a4518;
}

.route-arrow {
  color: #b9a89a;
  font-size: 70rpx;
}

.help-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 128rpx;
  margin-top: 48rpx;
  border-radius: 32rpx;
  background: #d94b43;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 900;
  padding-top: 0;
  padding-bottom: 0;
}

.help-button.help-holding {
  background: #b8322c;
  box-shadow: inset 0 0 0 8rpx #ffd0cc;
}

.config-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 100rpx;
  margin-top: 24rpx;
  padding-top: 0;
  padding-bottom: 0;
  border-radius: 24rpx;
  background: #fff5eb;
  color: #6f4b2d;
  font-size: 28rpx;
  font-weight: 500;
}

/* 未登录访客卡片 */
.guest-card {
  display: flex;
  flex-direction: column;
  padding: 48rpx 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 26rpx rgba(74, 47, 27, 0.07);
}

.guest-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #222222;
}

.guest-note {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #5a4e45;
}

.guest-family-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 112rpx;
  margin-top: 48rpx;
  border-radius: 32rpx;
  background: #ef8739;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 900;
  padding-top: 0;
  padding-bottom: 0;
}

.guest-elder-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 112rpx;
  margin-top: 24rpx;
  border-radius: 32rpx;
  background: #fff5eb;
  color: #6f4b2d;
  font-size: 40rpx;
  font-weight: 900;
  padding-top: 0;
  padding-bottom: 0;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx 32rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #5a4e45;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 32rpx;
  text-align: center;
}

.empty-state-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  border-radius: 50%;
  background: #fff1e3;
  color: #96521f;
  font-size: 60rpx;
  font-weight: 900;
  line-height: 120rpx;
  text-align: center;
}

.empty-state-text {
  color: #5a4e45;
  font-size: 28rpx;
  font-weight: 400;
}
