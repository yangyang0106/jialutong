# JIALUTONG_UPLOAD_TOKEN 已废弃，不再用于鉴权
# 超管微信 openid 列表（逗号分隔），用于测试和运维
JIALUTONG_SUPER_ADMIN_OPENIDS=
# 微信小程序凭证（必填，否则登录会返回 503）
JIALUTONG_WECHAT_APPID=
JIALUTONG_WECHAT_SECRET=
JIALUTONG_PUBLIC_BASE_URL=https://jialutong.cloud
JIALUTONG_DATA_DIR=/data

JIALUTONG_BAIDU_MAP_KEY=replace-with-baidu-server-ak

JIALUTONG_TENCENT_SECRET_ID=replace-with-tencent-secret-id
JIALUTONG_TENCENT_SECRET_KEY=replace-with-tencent-secret-key
JIALUTONG_TENCENT_TTS_REGION=ap-shanghai
JIALUTONG_TENCENT_TTS_VOICE_TYPE=101001

DEEPSEEK_API_KEY=replace-with-bailian-api-key
DEEPSEEK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_MODEL=qwen-plus
